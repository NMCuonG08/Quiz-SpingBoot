# =================================
# SERVER CONFIGURATION
# =================================
server.port=8080

# =================================
# PROFILE CONFIGURATION
# =================================
spring.profiles.active=dev

# =================================
# DATABASE CONFIGURATION
# =================================
# PostgreSQL Configuration
spring.datasource.url=jdbc:postgresql://localhost:5432/your_database_name
spring.datasource.username=your_db_username
spring.datasource.password=your_db_password
spring.datasource.driver-class-name=org.postgresql.Driver

# Connection Pool Configuration
spring.datasource.hikari.maximum-pool-size=20
spring.datasource.hikari.minimum-idle=5
spring.datasource.hikari.idle-timeout=300000
spring.datasource.hikari.max-lifetime=1200000
spring.datasource.hikari.connection-timeout=30000

# =================================
# JPA/HIBERNATE CONFIGURATION
# =================================
spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.use_sql_comments=true

# Performance Optimizations
spring.jpa.properties.hibernate.jdbc.batch_size=25
spring.jpa.properties.hibernate.order_inserts=true
spring.jpa.properties.hibernate.order_updates=true
spring.jpa.properties.hibernate.jdbc.batch_versioned_data=true

# Disable Second Level Cache (Using Spring Cache instead)
spring.jpa.properties.hibernate.cache.use_second_level_cache=false
spring.jpa.properties.hibernate.cache.use_query_cache=false

# =================================
# LOGGING CONFIGURATION
# =================================
logging.level.com.example=INFO
logging.level.org.springframework.security=DEBUG
logging.level.org.hibernate.SQL=DEBUG
logging.level.org.hibernate.type.descriptor.sql.BasicBinder=TRACE

# =================================
# ACTUATOR CONFIGURATION
# =================================
management.endpoints.web.exposure.include=health,info,metrics,prometheus
management.endpoint.health.show-details=when-authorized
management.metrics.export.prometheus.enabled=true

# =================================
# CACHE & REDIS CONFIGURATION
# =================================
spring.cache.type=redis
spring.cache.cache-names=employees,departments,leaveRequests,employeesByDepartment,managersList,categories

# Redis Connection details
spring.data.redis.host=localhost
spring.data.redis.port=6379

# =================================
# VALIDATION CONFIGURATION
# =================================
spring.jackson.deserialization.fail-on-unknown-properties=false
spring.jackson.serialization.write-dates-as-timestamps=false

# =================================
# CLOUDINARY CONFIGURATION
# =================================
cloudinary.cloud_name=your_cloudinary_cloud_name
cloudinary.api_key=your_cloudinary_api_key
cloudinary.api_secret=your_cloudinary_api_secret

# Google OAuth Configuration
google.client-id=${GOOGLE_CLIENT_ID:your_google_client_id}
google.client-secret=${GOOGLE_CLIENT_SECRET:your_google_client_secret}

# Application Info
app.title=Employee Management System API
app.version=1.0.0
app.description=A comprehensive employee management system with department and leave management capabilities
app.cors.allowed-origins=${ALLOWED_ORIGINS:http://localhost:3000,http://localhost:5173}

# =================================
# API DOCUMENTATION & SWAGGER
# =================================
springdoc.api-docs.path=/api-docs
springdoc.swagger-ui.path=/swagger-ui.html
springdoc.swagger-ui.operationsSorter=method
springdoc.swagger-ui.tagsSorter=alpha
springdoc.swagger-ui.displayRequestDuration=true
springdoc.swagger-ui.tryItOutEnabled=true
springdoc.swagger-ui.filter=true
springdoc.swagger-ui.enabled=true
springdoc.api-docs.enabled=true
springdoc.show-actuator=true

# Group API endpoints
springdoc.group-configs[0].group=employees
springdoc.group-configs[0].display-name=Employee Management
springdoc.group-configs[0].paths-to-match=/api/v1/employees/**

springdoc.group-configs[1].group=departments
springdoc.group-configs[1].display-name=Department Management
springdoc.group-configs[1].paths-to-match=/api/v1/departments/**

springdoc.group-configs[2].group=leave-requests
springdoc.group-configs[2].display-name=Leave Request Management
springdoc.group-configs[2].paths-to-match=/api/v1/leave-requests/**

springdoc.group-configs[3].group=authentication
springdoc.group-configs[3].display-name=Authentication
springdoc.group-configs[3].paths-to-match=/api/auth/**

springdoc.group-configs[4].group=images
springdoc.group-configs[4].display-name=Image Upload
springdoc.group-configs[4].paths-to-match=/api/images/**

springdoc.group-configs[5].group=quizzes
springdoc.group-configs[5].display-name=Quiz Management
springdoc.group-configs[5].paths-to-match=/api/quizzes/**

springdoc.group-configs[6].group=questions
springdoc.group-configs[6].display-name=Question Management
springdoc.group-configs[6].paths-to-match=/api/questions/**

springdoc.group-configs[7].group=quiz-sessions
springdoc.group-configs[7].display-name=Quiz Session Management
springdoc.group-configs[7].paths-to-match=/api/quiz-sessions/**

springdoc.group-configs[8].group=question-options
springdoc.group-configs[8].display-name=Question Option Management
springdoc.group-configs[8].paths-to-match=/api/question-options/**

springdoc.group-configs[9].group=categories
springdoc.group-configs[9].display-name=Category Management
springdoc.group-configs[9].paths-to-match=/api/categories/**

springdoc.group-configs[10].group=friends
springdoc.group-configs[10].display-name=Friend Management
springdoc.group-configs[10].paths-to-match=/api/friends/**

springdoc.group-configs[11].group=feedback
springdoc.group-configs[11].display-name=Feedback Management
springdoc.group-configs[11].paths-to-match=/api/feedback/**
